<!DOCTYPE html>
<html lang="en">
<head>
    <title>Snapture - Photography Studio</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Impact', 'Arial Black', sans-serif;
            overflow-x: hidden;
            background: white;
        }

        /* Navigation */
        nav {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 20px 60px;
            background: white;
            position: fixed;
            width: 100%;
            top: 0;
            z-index: 1000;
            border-bottom: 1px solid #eee;
        }

        .logo {
            font-size: 20px;
            font-weight: 900;
            letter-spacing: 1px;
        }

        .nav-links {
            display: flex;
            gap: 35px;
            list-style: none;
            align-items: center;
        }

        .nav-links a {
            text-decoration: none;
            color: #333;
            font-size: 11px;
            text-transform: uppercase;
            font-weight: 700;
            font-family: Arial, sans-serif;
            letter-spacing: 0.5px;
            transition: color 0.3s;
        }

        .nav-links a:hover {
            color: #ff6347;
        }

        .contact-btn {
            background: #2b2b2b;
            color: white !important;
            padding: 10px 25px;
            border-radius: 30px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .contact-btn i {
            background: #ff6347;
            padding: 8px;
            border-radius: 50%;
            font-size: 10px;
        }

        .explore-btn {
            background: #ff6347;
            color: white !important;
            padding: 10px 25px;
            border-radius: 30px;
            margin-left: 15px;
        }

        /* Main Container */
        .main-container {
            margin-top: 70px;
            display: grid;
            grid-template-columns: 60px 1fr 350px;
            gap: 0;
            min-height: 100vh;
        }

        /* Left Sidebar */
        .left-sidebar {
            background: #f8f4ed;
            display: flex;
            flex-direction: column;
            align-items: center;
            padding: 40px 0;
        }

        .sidebar-text {
            writing-mode: vertical-rl;
            transform: rotate(180deg);
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 2px;
            font-weight: 700;
            margin-top: 20px;
        }

        .sidebar-icon {
            margin-top: auto;
            color: #ff6347;
            font-size: 20px;
        }

        /* Center Content */
        .center-content {
            padding: 60px 80px;
        }

        /* Hero Section */
        .hero-section {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 40px;
            margin-bottom: 80px;
        }

        .hero-image {
            width: 100%;
            height: 550px;
            overflow: hidden;
            border-radius: 8px;
        }

        .hero-image img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .hero-title {
            font-size: 68px;
            line-height: 0.95;
            margin-bottom: 25px;
            font-weight: 900;
            text-transform: uppercase;
        }

        .hero-subtitle {
            font-size: 15px;
            color: #666;
            margin-bottom: 40px;
            line-height: 1.6;
            font-family: Arial, sans-serif;
        }

        .get-touch-btn {
            background: #ff6347;
            color: white;
            padding: 16px 45px;
            border: none;
            border-radius: 30px;
            font-size: 14px;
            font-weight: 700;
            cursor: pointer;
            text-transform: uppercase;
            font-family: Arial, sans-serif;
            transition: opacity 0.3s;
        }

        .get-touch-btn:hover {
            opacity: 0.9;
        }

        /* Photo Section */
        .photo-section {
            margin: 100px 0;
        }

        .photo-title {
            font-size: 46px;
            line-height: 1.15;
            font-weight: 900;
            text-transform: uppercase;
        }

        /* Legacy Section */
        .legacy-section {
            background: #e8dcc4;
            padding: 80px;
            border-radius: 8px;
            display: grid;
            grid-template-columns: 1.5fr 1fr 1fr;
            gap: 60px;
            align-items: center;
            margin: 80px 0;
        }

        .legacy-title {
            font-size: 42px;
            line-height: 1.1;
            font-weight: 900;
            text-transform: uppercase;
        }

        .legacy-text a {
            text-decoration: underline;
            color: #333;
            font-size: 13px;
            font-weight: 700;
        }

        /* Gallery Grid */
        .gallery-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 30px;
            margin: 80px 0;
        }

        .gallery-card {
            background: white;
            border: 1px solid #eee;
            border-radius: 8px;
            overflow: hidden;
        }

        .gallery-card img {
            width: 100%;
            height: 220px;
            object-fit: cover;
        }

        .gallery-card-content {
            padding: 25px;
        }

        .explore-link {
            background: #333;
            color: white;
            padding: 10px 20px;
            border-radius: 20px;
            text-decoration: none;
            font-size: 11px;
            text-transform: uppercase;
            font-weight: 700;
            display: inline-block;
            font-family: Arial, sans-serif;
        }

        /* Right Sidebar */
        .right-sidebar {
            background: #f8f4ed;
            padding: 40px 30px;
        }

        .sidebar-title {
            font-size: 32px;
            line-height: 1.1;
            font-weight: 900;
            text-transform: uppercase;
            margin-bottom: 40px;
        }

        .sidebar-card {
            background: white;
            padding: 25px;
            border-radius: 8px;
            margin-bottom: 25px;
        }

        .sidebar-card img {
            width: 100%;
            height: 140px;
            object-fit: cover;
            border-radius: 6px;
            margin-bottom: 15px;
        }

        /* Footer */
        footer {
            background: #030303;
            color: white;
            padding: 60px 80px 30px;
        }

        .footer-grid {
            display: grid;
            grid-template-columns: 1.5fr 1fr 1fr 1fr;
            gap: 60px;
            margin-bottom: 40px;
        }

        .footer-logo {
            font-size: 22px;
            font-weight: 600;
            margin-bottom: 20px;
        }

        @media (max-width: 1200px) {
            .main-container {
                grid-template-columns: 1fr;
            }
            .right-sidebar, .left-sidebar {
                display: none;
            }
        }
    </style>
</head>
<body>
    <nav>
        <div class="logo">SNAPTURE.</div>
        <ul class="nav-links">
            <li><a href="#about">ABOUT</a></li>
            <li><a href="#photography">PHOTOGRAPHY</a></li>
            <li><a href="#event">EVENT</a></li>
            <li><a href="#contact" class="contact-btn">Contact <i class="fas fa-paper-plane"></i></a></li>
