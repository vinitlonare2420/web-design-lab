                <div class="legacy-text">
                    <p>Photography is more than pictures.</p>
                    <a href="#">See Our Projects</a>
                </div>
            </div>

            <div class="gallery-grid">
                <div class="gallery-card">
                    <img src="https://images.unsplash.com/photo-1509316785289-025f5b846b35?w=500&q=80" alt="Nature">
                    <div class="gallery-card-content">
                        <a href="#" class="explore-link">Explore Now</a>
                    </div>
                </div>
                <div class="gallery-card">
                    <img src="https://images.unsplash.com/photo-1600596542815-ffad4c1539a9?w=500&q=80" alt="Real Estate">
                    <div class="gallery-card-content">
                        <a href="#" class="explore-link">Book Now</a>
                    </div>
                </div>
                <div class="gallery-card">
                    <img src="https://images.unsplash.com/photo-1506905925346-21bda4d32df4?w=500&q=80" alt="Wild">
                    <div class="gallery-card-content">
                        <a href="#" class="explore-link">Explore Now</a>
                    </div>
                </div>
            </div>
        </div>

        <div class="right-sidebar">
            <h2 class="sidebar-title">ELEVATING MOMENTS</h2>
            <div class="sidebar-card">
                <img src="https://images.unsplash.com/photo-1502982899975-c079c12b5f8c?w=400&q=80" alt="Side">
                <p style="font-size: 11px; font-family: Arial;">Capturing the true essence of light.</p>
            </div>
        </div>
    </div>

    <footer>
        <div class="footer-grid">
            <div>
                <div class="footer-logo">SNAPTURE.</div>
                <p style="color: #999; font-size: 13px; font-family: Arial;">vinitlonare0@gmail.com<br>
                Contract Information:- 9370606390<br> Address:- Nagpur Maharastra 440030</p>
            </div>
            <div class="footer-section">
                <h4 style="font-size: 14px; text-transform: uppercase; margin-bottom: 20px;">Portfolio</h4>
                <p style="color: #999; font-size: 13px; font-family: Arial;">Photography<br>Cinematography</p>
            </div>
        </div>
    </footer>
</body>
</html>